{
  "compilerOptions": {
    "strict": true,
    "module": "node16",
    "target": "ES2021",
    "lib": ["ES2021"],
    "declaration": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true
  },
  "include": ["credentials/**/*", "nodes/**/*", "index.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
